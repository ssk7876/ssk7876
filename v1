// ═══════════════════════════════════════
//  SIGNATURE PAD
// ═══════════════════════════════════════
let sigDataURL = null;   // 저장된 서명 이미지
let sigCtx     = null;
let sigDrawing = false;
let sigLastX   = 0, sigLastY = 0;
let sigHasMark = false;  // 한 획이라도 그렸는지

function openSigModal() {
  document.getElementById('sigModalBg').style.display='flex';
  initSigCanvas();
  // 기존 서명이 있으면 불러오기
  if(sigDataURL) {
    const img=new Image();
    img.onload=()=>sigCtx.drawImage(img,0,0);
    img.src=sigDataURL;
    document.getElementById('sigHint').style.display='none';
    sigHasMark=true;
  } else {
    document.getElementById('sigHint').style.display='block';
    sigHasMark=false;
  }
}

function closeSigModal() {
  document.getElementById('sigModalBg').style.display='none';
}

function initSigCanvas() {
  const wrap = document.getElementById('sigCanvasWrap');
  const canvas = document.getElementById('sigCanvas');
  const W = wrap.clientWidth;
  const H = Math.round(W * 0.38);   // 가로 대비 38% 높이
  canvas.width  = W;
  canvas.height = H;
  canvas.style.height = H+'px';
  sigCtx = canvas.getContext('2d');
  sigCtx.fillStyle='#fff';
  sigCtx.fillRect(0,0,W,H);
  sigCtx.strokeStyle='#1a2540';
  sigCtx.lineWidth=2.5;
  sigCtx.lineCap='round';
  sigCtx.lineJoin='round';
  bindSigEvents(canvas);
}

function bindSigEvents(canvas) {
  // 중복 바인딩 방지
  const fresh = canvas.cloneNode(true);
  canvas.parentNode.replaceChild(fresh, canvas);
  const c = document.getElementById('sigCanvas');
  sigCtx = c.getContext('2d');
  sigCtx.strokeStyle='#1a2540';
  sigCtx.lineWidth=2.5;
  sigCtx.lineCap='round';
  sigCtx.lineJoin='round';

  function getPos(e) {
    const rect=c.getBoundingClientRect();
    const scaleX=c.width/rect.width;
    const scaleY=c.height/rect.height;
    if(e.touches){ return { x:(e.touches[0].clientX-rect.left)*scaleX, y:(e.touches[0].clientY-rect.top)*scaleY }; }
    return { x:(e.clientX-rect.left)*scaleX, y:(e.clientY-rect.top)*scaleY };
  }
  function start(e){ e.preventDefault(); sigDrawing=true; const p=getPos(e); sigLastX=p.x; sigLastY=p.y; sigCtx.beginPath(); sigCtx.moveTo(p.x,p.y); }
  function move(e){ e.preventDefault(); if(!sigDrawing)return; const p=getPos(e); sigCtx.lineTo(p.x,p.y); sigCtx.stroke(); sigLastX=p.x; sigLastY=p.y; sigHasMark=true; document.getElementById('sigHint').style.display='none'; }
  function end(e){ e.preventDefault(); sigDrawing=false; }

  c.addEventListener('mousedown',start);
  c.addEventListener('mousemove',move);
  c.addEventListener('mouseup',end);
  c.addEventListener('mouseleave',end);
  c.addEventListener('touchstart',start,{passive:false});
  c.addEventListener('touchmove',move,{passive:false});
  c.addEventListener('touchend',end,{passive:false});
}

function clearSig() {
  const c=document.getElementById('sigCanvas');
  sigCtx=c.getContext('2d');
  sigCtx.fillStyle='#fff';
  sigCtx.fillRect(0,0,c.width,c.height);
  sigHasMark=false;
  sigDataURL=null;
  document.getElementById('sigHint').style.display='block';
  updateSignBtn();
}

function confirmSig() {
  if(!sigHasMark){ showToast('서명을 먼저 해주세요'); return; }
  const c=document.getElementById('sigCanvas');
  sigDataURL=c.toDataURL('image/png');
  closeSigModal();
  updateSignBtn();
  showToast('서명이 저장되었습니다 ✅');
}

function updateSignBtn() {
  const btn=document.getElementById('signBtn');
  if(sigDataURL){
    btn.className='sign-btn signed';
    btn.innerHTML=`<img src="${sigDataURL}" alt="서명" style="max-width:72px;max-height:38px;">`;
  } else {
    btn.className='sign-btn empty';
    btn.innerHTML='✍️ 서명';
  }
}

