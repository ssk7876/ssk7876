<!-- CONTENT PICKER -->
<div id="pickerOverlay" class="picker-overlay" style="display:none;" onclick="closePicker()"></div>
<div id="contentPicker" class="content-picker" style="display:none;">
  <div class="picker-header">
    <span>⚡ 활동내용 선택</span>
    <button class="picker-close" onclick="closePicker()">✕</button>
  </div>
  <div class="picker-list" id="pickerList"></div>
</div>

<div class="toast" id="toast"></div>

<script>
// ═══════════════════════════════════════
//  CONFIG
// ═══════════════════════════════════════
const CROP = {
  rice:  {name:'벼',   emoji:'🌾',color:'var(--rice)', bg:'var(--rice-bg)', lt:'var(--rice-lt)', badge:'badge-rice',  cls:'rice',
          regions:['정읍','김제','익산','군산','남원','부안','무주']},
  grain: {name:'맥류', emoji:'🌿',color:'var(--grain)',bg:'var(--grain-bg)',lt:'var(--grain-lt)',badge:'badge-grain',cls:'grain',
          regions:['정읍','김제','군산','부안','고창']},
  bean:  {name:'콩',   emoji:'🫘',color:'var(--bean)', bg:'var(--bean-bg)', lt:'var(--bean-lt)', badge:'badge-bean',  cls:'bean',
          regions:['정읍','고창','임실','진안','부안','김제']},
};
// QUICK_ITEMS는 아래 picker 섹션에 정의

// ═══════════════════════════════════════
//  DB
// ═══════════════════════════════════════
let db = JSON.parse(localStorage.getItem('cj3') || '{"workers":[],"reports":[],"adminPw":"admin1234"}');
const save = () => localStorage.setItem('cj3', JSON.stringify(db));

// ═══════════════════════════════════════
//  STATE
// ═══════════════════════════════════════
let mode = 'worker';
let selCrop = 'rice';
let selRegion = '';
let selWorker = null;
let focusedContent = null;
let rowSeq = 0;
let adminMonth = new Date().toISOString().slice(0,7);
let adminCropF = 'rice';

// 로그인 상태
let loginType = null;   // 'worker' | 'admin'
let loginWorkerObj = null;  // 로그인한 지도원 객체

// ═══════════════════════════════════════
//  MODE SWITCH
// ═══════════════════════════════════════
function setMode(m) {
  mode = m;
  ['workerMode','workerNav'].forEach(id => document.getElementById(id).style.display = m==='worker'?'block':'none');
  document.getElementById('workerNav').style.display = m==='worker'?'flex':'none';
  ['adminMode','adminNav'].forEach(id => document.getElementById(id).style.display = m==='admin'?'block':'none');
  document.getElementById('adminNav').style.display = m==='admin'?'flex':'none';
  document.getElementById('pWorker').className = 'mode-pill'+(m==='worker'?' on':'');
  document.getElementById('pAdmin').className  = 'mode-pill'+(m==='admin'?' on':'');
  if(m==='admin') { buildAdminMonthStrip(); refreshAdminDash(); updateAdminListFilters(); }
}

// ═══════════════════════════════════════
//  TABS
// ═══════════════════════════════════════
function switchWorkerTab(t, btn) {
  document.querySelectorAll('#workerNav .btm-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  document.querySelectorAll('#workerMode .page').forEach(p=>p.classList.remove('on'));
  document.getElementById('pw-'+t).classList.add('on');
  if(t==='home') renderHome();
  if(t==='write') { if(!selWorker){showToast('먼저 홈에서 지도원을 선택하세요');return;} initWriteForm(); }
  if(t==='history') renderHistory();
}
function switchAdminTab(t, btn) {
  document.querySelectorAll('#adminNav .btm-btn').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  document.querySelectorAll('#adminMode .page').forEach(p=>p.classList.remove('on'));
  document.getElementById('pa-'+t).classList.add('on');
  if(t==='dash')    refreshAdminDash();
  if(t==='list')    { updateAdminListFilters(); renderAdminList(); }
  if(t==='workers') renderAdminWorkers();
}

// ═══════════════════════════════════════
//  HOME
// ═══════════════════════════════════════
function renderHome() {
  // 지도원 로그인: 작물·지역 탭 숨기고 본인 카드만 표시
  const isWorkerLogin = loginType==='worker' && loginWorkerObj;
  document.getElementById('cropTabsWrap').style.display = isWorkerLogin?'none':'block';
  document.getElementById('groupTabs').style.display    = isWorkerLogin?'none':'flex';
  if(isWorkerLogin){
    selCrop=loginWorkerObj.crop; selRegion=loginWorkerObj.region; selWorker=loginWorkerObj;
    renderWorkerList();
  } else {
    buildRegionTabs();
    renderWorkerList();
  }
}

function selectCrop(c, el) {
  selCrop=c; selRegion='';
  document.querySelectorAll('.crop-tab').forEach(t=>t.classList.remove('on'));
  el.classList.add('on');
  buildRegionTabs(); renderWorkerList();
}

function buildRegionTabs() {
  const ci=CROP[selCrop];
  if(!selRegion) selRegion=ci.regions[0];
  document.getElementById('groupTabs').innerHTML = ci.regions.map(r=>{
    const on = selRegion===r;
    return `<button class="group-tab" onclick="selectRegion('${r}',this)"
      style="${on?`border-color:${ci.color};background:${ci.bg};color:${ci.color};`:''}"
    >${r}</button>`;
  }).join('');
}

function selectRegion(r, el) {
  selRegion=r;
  const ci=CROP[selCrop];
  document.querySelectorAll('.group-tab').forEach(b=>{ b.style.borderColor=''; b.style.background=''; b.style.color=''; });
  el.style.borderColor=ci.color; el.style.background=ci.bg; el.style.color=ci.color;
  renderWorkerList();
}

function renderWorkerList() {
  const ci=CROP[selCrop];
  // 지도원 로그인 시 본인만 표시
  let list;
  if(loginType==='worker' && loginWorkerObj){
    list=[loginWorkerObj];
  } else {
    list=db.workers.filter(w=>w.crop===selCrop&&w.region===selRegion);
  }
  const el=document.getElementById('workerListHome');
  if(!list.length){
    el.innerHTML=`<div class="empty"><div class="ei">👤</div><p>${ci.emoji} ${ci.name} ${selRegion} 지도원이 없습니다</p></div>`; return;
  }
  el.innerHTML=list.map(w=>{
    const mRpts=db.reports.filter(r=>r.workerId===w.id&&r.month===new Date().toISOString().slice(0,7));
    const isSel=selWorker&&selWorker.id===w.id;
    const wci=CROP[w.crop]||ci;
    return `<div class="worker-card ${isSel?'selected':''}" onclick="pickWorker('${w.id}',this)">
      <div class="w-avatar" style="background:${wci.bg};color:${wci.color};">${w.name[0]}</div>
      <div class="w-info">
        <div class="w-name">${w.name}</div>
        <div class="w-detail">${wci.emoji} ${wci.name} · ${w.region} · ${w.unit||'단지미지정'}</div>
      </div>
      <div style="text-align:right;font-size:11px;color:var(--muted);">
        <span style="font-size:18px;font-weight:900;font-family:'JetBrains Mono',monospace;color:${wci.color};display:block;">${mRpts.length}</span>
        이번달 제출
      </div>
    </div>`;
  }).join('');
  // 자동 선택
  if(list.length===1 && !selWorker){
    selWorker=list[0];
    document.querySelector('.worker-card')?.classList.add('selected');
  }
}

function pickWorker(id, el) {
  selWorker=db.workers.find(w=>w.id===id);
  document.querySelectorAll('.worker-card').forEach(c=>c.classList.remove('selected'));
  el.classList.add('selected');
}

function goToInput() {
  if(!selWorker){showToast('지도원을 선택하세요'); return;}
  initWriteForm();
  document.querySelectorAll('#workerNav .btm-btn')[1].click();
}
function goHome() { document.querySelectorAll('#workerNav .btm-btn')[0].click(); }

// ═══════════════════════════════════════
//  REGISTER
// ═══════════════════════════════════════
function updateRegionSelect() {
  const crop=document.getElementById('rCrop').value;
  const sel=document.getElementById('rRegion');
  sel.innerHTML=CROP[crop].regions.map(r=>`<option value="${r}">${r}</option>`).join('');
}

function toggleRegPanel() {
  const p=document.getElementById('regPanel');
  p.style.display=p.style.display==='none'?'block':'none';
  if(p.style.display==='block') updateRegionSelect();
}
function registerWorker() {
  const name=document.getElementById('rName').value.trim();
  const crop=document.getElementById('rCrop').value;
  const region=document.getElementById('rRegion').value;
  const unit=document.getElementById('rUnit').value.trim();
  if(!name){showToast('이름을 입력하세요');return;}
  db.workers.push({id:Date.now().toString(),name,crop,region,unit});
  save(); renderHome();
  document.getElementById('rName').value='';
  document.getElementById('rUnit').value='';
  document.getElementById('regPanel').style.display='none';
  selCrop=crop; selRegion=region;
  document.querySelectorAll('.crop-tab').forEach(t=>t.classList.remove('on'));
  document.querySelector('.crop-tab.'+crop).classList.add('on');
  buildRegionTabs(); renderWorkerList();
  showToast(`${name} 지도원 등록 완료 ✅`);
}

// ═══════════════════════════════════════
//  WRITE FORM
// ═══════════════════════════════════════
function initWriteForm() {
  if(!selWorker) return;
  const ci=CROP[selWorker.crop];
  // 상단 배지
  const av=document.getElementById('myAvatar');
  av.textContent=selWorker.name[0]; av.style.background=ci.bg; av.style.color=ci.color;
  document.getElementById('myName').textContent=selWorker.name;
  document.getElementById('myDetail').textContent=`${ci.emoji} ${ci.name} · ${selWorker.region||''} · ${selWorker.unit||'단지미지정'}`;

  // 기본값 — 단지명은 지도원 등록 정보에서 자동 세팅
  const now=new Date();
  document.getElementById('selMonth').value=now.getMonth()+1;
  const workerUnit = selWorker.unit||'';
  document.getElementById('inUnit').value=workerUnit;
  document.getElementById('inSignName').value=selWorker.name;
  syncSignUnit();

  // 기존 draft 불러오기
  const mk=`${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;
  const exist=db.reports.find(r=>r.workerId===selWorker.id&&r.month===mk);
  if(exist){
    document.getElementById('inPeriod').value=exist.period||'';
    document.getElementById('inDays').value=exist.days!==undefined ? exist.days : 12;
    document.getElementById('inUnit').value=exist.unit||selWorker.unit||'';
    // 서명 복원
    sigDataURL = exist.signatureImg||null;
    updateSignBtn();
