  if(v) autoFillDates(parseInt(v));
}

function autoFillDates(month) {
  const now=new Date();
  const year=now.getFullYear();
  const daysInMonth=new Date(year, month, 0).getDate();

  // 근무기간 자동 설정, 근무일수 기본 12일
  document.getElementById('inPeriod').value=`${month}.1 ~ ${month}.${daysInMonth}`;
  document.getElementById('inDays').value=12;   // 기본 12일 고정

  // 기존 행 초기화 후 기본 12행 생성 (날짜·시간 기본값 포함)
  rowSeq=0; document.getElementById('actTbody').innerHTML='';
  for(let i=0;i<12;i++) addRow('',3,'');        // 활동시간 기본 3시간
}
function syncSignUnit() {
  const u=document.getElementById('inUnit').value||'　　';
  document.getElementById('signUnitDisp').textContent=`(${u})`;
}

function initRows(n) {
