  document.getElementById('adminMonthStrip').innerHTML=months.map(m=>`
    <div class="m-chip ${m===adminMonth?'on':''}" onclick="setAdminMonth('${m}',this)">
      ${m.slice(0,4)}년 ${parseInt(m.slice(5,7))}월
    </div>`).join('');
}
function setAdminMonth(m,el){
  adminMonth=m;
  document.querySelectorAll('.m-chip').forEach(c=>c.classList.remove('on'));
  el.classList.add('on');
  renderAdminList(); refreshAdminDash();
}

// ═══════════════════════════════════════
//  ADMIN LIST
// ═══════════════════════════════════════
function updateAdminListFilters() {
  const sel=document.getElementById('fWorker');
  sel.innerHTML='<option value="">전체</option>';
  db.workers.forEach(w=>{ const ci=CROP[w.crop]; sel.innerHTML+=`<option value="${w.id}">${w.name} (${ci.emoji} ${w.region||''})</option>`; });
  updateRegionFilter();
}

function updateRegionFilter() {
  const fCropVal=document.getElementById('fCrop').value;
  const regSel=document.getElementById('fGroup');
  regSel.innerHTML='<option value="">전체</option>';
  if(fCropVal && CROP[fCropVal]) {
    CROP[fCropVal].regions.forEach(r=>{ regSel.innerHTML+=`<option value="${r}">${r}</option>`; });
  } else {
    // 전체 작물일 때 전 지역 합집합
    const allRegions=[...new Set(Object.values(CROP).flatMap(c=>c.regions))].sort();
    allRegions.forEach(r=>{ regSel.innerHTML+=`<option value="${r}">${r}</option>`; });
  }
}
function renderAdminList() {
  const fC=document.getElementById('fCrop').value;
  const fG=document.getElementById('fGroup').value;
  const fW=document.getElementById('fWorker').value;
  let rpts=db.reports.filter(r=>r.month===adminMonth);
  if(fC) rpts=rpts.filter(r=>r.crop===fC);
  if(fG) rpts=rpts.filter(r=>r.region===fG);
  if(fW) rpts=rpts.filter(r=>r.workerId===fW);
  rpts.sort((a,b)=>b.savedAt.localeCompare(a.savedAt));

  const el=document.getElementById('adminReportList');
  if(!rpts.length){ el.innerHTML='<div class="empty"><div class="ei">🔍</div><p>해당 조건의 지도부가 없습니다</p></div>'; return; }

  const totalActs=rpts.reduce((s,r)=>s+(r.rows||[]).filter(x=>x.content).length,0);
  el.innerHTML=`<div class="card" style="background:linear-gradient(135deg,var(--navy),#2a3d70);color:white;border:none;padding:12px 16px;margin-bottom:12px;">
    <div style="display:flex;justify-content:space-around;text-align:center;">
      <div><div style="font-size:20px;font-weight:900;font-family:'JetBrains Mono',monospace">${rpts.length}</div><div style="font-size:10px;opacity:0.7">제출</div></div>
      <div><div style="font-size:20px;font-weight:900;font-family:'JetBrains Mono',monospace">${totalActs}</div><div style="font-size:10px;opacity:0.7">활동건</div></div>
      <div><div style="font-size:20px;font-weight:900;font-family:'JetBrains Mono',monospace">${rpts.reduce((s,r)=>s+parseInt(r.days||0),0)}</div><div style="font-size:10px;opacity:0.7">근무일</div></div>
    </div>
  </div>`+rpts.map(r=>{
    const ci=CROP[r.crop]; const acts=(r.rows||[]).filter(x=>x.content);
    return `<div class="report-item">
      <div class="ri-top">
        <div>
          <div class="ri-title">${r.workerName}</div>
          <span class="crop-badge ${ci.badge}">${ci.emoji} ${ci.name} · ${r.region||''}</span>
        </div>
        <div class="ri-date">${r.month}</div>
      </div>
      <div class="ri-meta">
        <span>📅 ${r.period||'-'}</span><span>📆 ${r.days||0}일</span>
        <span>📋 ${acts.length}건</span><span>🏡 ${r.unit||'-'}</span>
      </div>
      ${acts.slice(0,3).map(row=>`
        <div style="font-size:11px;color:var(--muted);margin-top:3px;padding-left:6px;border-left:2px solid var(--border);">
          ${row.date} · ${row.time?row.time+'h':'-'} · ${row.content}
        </div>`).join('')}
      ${acts.length>3?`<div style="font-size:10px;color:var(--muted);margin-top:3px;">... 외 ${acts.length-3}건</div>`:''}
    </div>`;
  }).join('');
}

// ═══════════════════════════════════════
//  ADMIN WORKERS
// ═══════════════════════════════════════
function setAdminCropFilter(c,el) {
  adminCropF=c;
  document.querySelectorAll('#adminCropFilter .crop-tab').forEach(t=>t.classList.remove('on'));
  el.classList.add('on');
  renderAdminWorkers();
}
function renderAdminWorkers() {
  const ci=CROP[adminCropF];
  const workers=db.workers.filter(w=>w.crop===adminCropF);
  const el=document.getElementById('adminWorkersByGroup');
  if(!workers.length){ el.innerHTML=`<div class="empty"><div class="ei">${ci.emoji}</div><p>${ci.name} 지도원이 없습니다</p></div>`; return; }
  let html='';
  ci.regions.forEach(region=>{
    const rw=workers.filter(w=>w.region===region);
    if(!rw.length) return;
    html+=`<div class="card"><div class="card-hd" style="color:${ci.color}">${ci.emoji} ${ci.name} · ${region}
      <span style="font-weight:400;font-size:11px;color:var(--muted);">(${rw.length}명)</span></div>`;
    rw.forEach(w=>{
      const mR=db.reports.filter(r=>r.workerId===w.id&&r.month===adminMonth);
      const allR=db.reports.filter(r=>r.workerId===w.id);
      html+=`<div class="worker-card" style="margin-bottom:6px;">
        <div class="w-avatar" style="background:${ci.bg};color:${ci.color};">${w.name[0]}</div>
        <div class="w-info"><div class="w-name">${w.name}</div><div class="w-detail">${w.unit||'단지미지정'}</div></div>
        <div style="text-align:right;">
          <span style="font-size:12px;font-weight:700;padding:2px 8px;border-radius:10px;background:${ci.bg};color:${ci.color};">${mR.length}건</span>
          <div style="font-size:10px;color:var(--muted);margin-top:2px;">누적 ${allR.length}건</div>
        </div>
      </div>`;
    });
    html+='</div>';
  });
  el.innerHTML=html;
}

// ═══════════════════════════════════════
//  LOGIN
// ═══════════════════════════════════════
function initLoginScreen() {
  updateLoginUnitList();
  updateRlRegion();
  document.getElementById('loginScreen').style.display='flex';
  // 앱 전체 숨김
  document.getElementById('workerMode').style.display='none';
  document.getElementById('adminMode').style.display='none';
  document.getElementById('workerNav').style.display='none';
  document.getElementById('adminNav').style.display='none';
  document.getElementById('modePills').style.display='none';
  document.getElementById('appBarUser').style.display='none';
}

function switchLoginTab(t) {
  document.getElementById('ltWorker').className='login-tab'+(t==='worker'?' on':'');
  document.getElementById('ltAdmin').className='login-tab'+(t==='admin'?' on':'');
  document.getElementById('loginWorkerForm').style.display=t==='worker'?'block':'none';
  document.getElementById('loginAdminForm').style.display=t==='admin'?'block':'none';
  document.getElementById('loginRegCard').style.display='none';
  clearLoginErr();
}

function updateLoginUnitList() {
  const crop=document.getElementById('lCrop').value;
  const workers=db.workers.filter(w=>w.crop===crop);
  const sel=document.getElementById('lUnit');
  if(!workers.length){
    sel.innerHTML='<option value="">등록된 지도원 없음</option>';
  } else {
    sel.innerHTML=workers.map(w=>`<option value="${w.id}">${w.name} (${w.region} · ${w.unit||'단지미지정'})</option>`).join('');
  }
}

function doWorkerLogin() {
  const workerId=document.getElementById('lUnit').value;
  const pw=document.getElementById('lPw').value;
  if(!workerId){showLoginErr('지도원을 선택하세요');return;}
  if(!pw){showLoginErr('비밀번호를 입력하세요');return;}
  const worker=db.workers.find(w=>w.id===workerId);
  if(!worker){showLoginErr('지도원 정보를 찾을 수 없습니다');return;}
  if(!worker.pw){showLoginErr('비밀번호가 설정되지 않았습니다. 관리자에게 문의하세요');return;}
  if(worker.pw!==pw){showLoginErr('비밀번호가 올바르지 않습니다');return;}

  // 로그인 성공
  loginType='worker';
  loginWorkerObj=worker;
  selWorker=worker;
  selCrop=worker.crop;
  selRegion=worker.region;
  enterApp('worker');
}

function doAdminLogin() {
  const pw=document.getElementById('lAdminPw').value;
  if(!pw){showLoginAdminErr('비밀번호를 입력하세요');return;}
  if(pw!==db.adminPw){showLoginAdminErr('관리자 비밀번호가 올바르지 않습니다');return;}
  loginType='admin';
  loginWorkerObj=null;
  enterApp('admin');
}

function enterApp(type) {
  document.getElementById('loginScreen').style.display='none';
  document.getElementById('lPw').value='';
  document.getElementById('lAdminPw').value='';
  clearLoginErr();

  if(type==='worker'){
    document.getElementById('workerMode').style.display='block';
    document.getElementById('workerNav').style.display='flex';
    document.getElementById('appBarUser').style.display='flex';
    document.getElementById('appBarUserName').textContent=loginWorkerObj.name+' 지도원';
    document.getElementById('modePills').style.display='none';
    renderHome();
    // 해당 지도원 자동 선택
    setTimeout(()=>{
      document.querySelectorAll('.crop-tab').forEach(t=>t.classList.remove('on'));
      document.querySelector('.crop-tab.'+selWorker.crop).classList.add('on');
      buildRegionTabs();
      renderWorkerList();
      // 자동으로 자신의 카드 선택
      const card=document.querySelector(`.worker-card[onclick*="${selWorker.id}"]`);
      if(card){card.classList.add('selected');}
    },50);
  } else {
    document.getElementById('adminMode').style.display='block';
    document.getElementById('adminNav').style.display='flex';
    document.getElementById('modePills').style.display='none';
    document.getElementById('appBarUser').style.display='flex';
    document.getElementById('appBarUserName').textContent='관리자';
    refreshAdminDash();
    buildAdminMonthStrip();
    updateAdminListFilters();
  }
}

function doLogout() {
  if(!confirm('로그아웃 하시겠습니까?')) return;
  loginType=null; loginWorkerObj=null; selWorker=null;
  document.getElementById('workerMode').style.display='none';
  document.getElementById('adminMode').style.display='none';
  document.getElementById('workerNav').style.display='none';
  document.getElementById('adminNav').style.display='none';
  document.getElementById('modePills').style.display='none';
  document.getElementById('appBarUser').style.display='none';
  // 로그인 화면 리셋
  switchLoginTab('worker');
  updateLoginUnitList();
  initLoginScreen();
}

function showLoginErr(msg) {
  const el=document.getElementById('loginErr');
  el.textContent='⚠️ '+msg; el.style.display='block';
}
function showLoginAdminErr(msg) {
  const el=document.getElementById('loginAdminErr');
  el.textContent='⚠️ '+msg; el.style.display='block';
}
function clearLoginErr() {
  const e1=document.getElementById('loginErr');
  const e2=document.getElementById('loginAdminErr');
  if(e1) e1.style.display='none';
  if(e2) e2.style.display='none';
}

// ── 로그인 화면에서 지도원 등록 ──
function showRegisterFromLogin() {
  document.getElementById('loginRegCard').style.display='block';
  updateRlRegion();
}
function hideRegFromLogin() {
  document.getElementById('loginRegCard').style.display='none';
}
function updateRlRegion() {
  const crop=document.getElementById('rlCrop').value;
  const sel=document.getElementById('rlRegion');
  sel.innerHTML=CROP[crop].regions.map(r=>`<option value="${r}">${r}</option>`).join('');
}
function doRegisterFromLogin() {
  const name=document.getElementById('rlName').value.trim();
  const crop=document.getElementById('rlCrop').value;
  const region=document.getElementById('rlRegion').value;
  const unit=document.getElementById('rlUnit').value.trim();
  const pw=document.getElementById('rlPw').value;
  const pw2=document.getElementById('rlPw2').value;
  const errEl=document.getElementById('rlErr');
  errEl.style.display='none';

  if(!name){errEl.textContent='⚠️ 이름을 입력하세요';errEl.style.display='block';return;}
  if(!unit){errEl.textContent='⚠️ 단지명을 입력하세요';errEl.style.display='block';return;}
  if(pw.length<4){errEl.textContent='⚠️ 비밀번호는 4자리 이상이어야 합니다';errEl.style.display='block';return;}
  if(pw!==pw2){errEl.textContent='⚠️ 비밀번호가 일치하지 않습니다';errEl.style.display='block';return;}

  const worker={id:Date.now().toString(),name,crop,region,unit,pw};
  db.workers.push(worker);
  save();

  // 폼 초기화
  document.getElementById('rlName').value='';
  document.getElementById('rlUnit').value='';
  document.getElementById('rlPw').value='';
  document.getElementById('rlPw2').value='';
  document.getElementById('loginRegCard').style.display='none';

  // 로그인 폼 업데이트
  document.getElementById('lCrop').value=crop;
  updateLoginUnitList();
  setTimeout(()=>{
    const sel=document.getElementById('lUnit');
    for(let i=0;i<sel.options.length;i++){
      if(sel.options[i].value===worker.id){sel.selectedIndex=i;break;}
    }
  },50);

  showToast(`${name} 지도원 등록 완료! 로그인하세요 ✅`);
}

// ── 비밀번호 변경 ──
function openPwModal() {
  document.getElementById('pwOld').value='';
  document.getElementById('pwNew').value='';
  document.getElementById('pwNew2').value='';
  document.getElementById('pwErr').style.display='none';
  document.getElementById('pwModalBg').style.display='flex';
}
function closePwModal() {
  document.getElementById('pwModalBg').style.display='none';
}
function confirmPwChange() {
  const old=document.getElementById('pwOld').value;
  const nw=document.getElementById('pwNew').value;
  const nw2=document.getElementById('pwNew2').value;
  const errEl=document.getElementById('pwErr');
  errEl.style.display='none';

  if(loginType==='worker'){
    if(old!==loginWorkerObj.pw){errEl.textContent='현재 비밀번호가 올바르지 않습니다';errEl.style.display='block';return;}
    if(nw.length<4){errEl.textContent='새 비밀번호는 4자리 이상이어야 합니다';errEl.style.display='block';return;}
    if(nw!==nw2){errEl.textContent='새 비밀번호가 일치하지 않습니다';errEl.style.display='block';return;}
    const idx=db.workers.findIndex(w=>w.id===loginWorkerObj.id);
    if(idx>=0){db.workers[idx].pw=nw; loginWorkerObj.pw=nw; selWorker.pw=nw;}
  } else {
    if(old!==db.adminPw){errEl.textContent='현재 관리자 비밀번호가 올바르지 않습니다';errEl.style.display='block';return;}
    if(nw.length<4){errEl.textContent='새 비밀번호는 4자리 이상이어야 합니다';errEl.style.display='block';return;}
    if(nw!==nw2){errEl.textContent='새 비밀번호가 일치하지 않습니다';errEl.style.display='block';return;}
    db.adminPw=nw;
  }
  save();
  closePwModal();
  showToast('비밀번호가 변경되었습니다 🔒');
}

// ═══════════════════════════════════════
//  TOAST
// ═══════════════════════════════════════
function showToast(msg) {
  const t=document.getElementById('toast'); t.textContent=msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2600);
}

// ═══ INIT ═══
initLoginScreen();
buildAdminMonthStrip();
</script>
</body>
</html>
