    signatureImg: sigDataURL||null
  };
  const idx=db.reports.findIndex(r=>r.workerId===selWorker.id&&r.month===month);
  if(idx>=0) db.reports[idx]=rep; else db.reports.push(rep);
  save();
  showToast('저장되었습니다 ✅');
}

